# Example .env for this project. Copy to .env and fill values.
# Do NOT commit real secrets to git.

# Django secret key
DJANGO_SECRET_KEY=replace-me-with-a-strong-secret

# Debug (True/False)
DJANGO_DEBUG=True

# Allowed hosts (comma separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Language and timezone
DJANGO_LANGUAGE=uk
DJANGO_TIME_ZONE=Europe/Kiev

# Email backend. For development you can use the console backend:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use smtp backend and set EMAIL_HOST/EMAIL_PORT/etc.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# If using SMTP, set the following values (example):
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=supersecret
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False

# Default sender address for outgoing emails
DEFAULT_FROM_EMAIL=no-reply@example.com
